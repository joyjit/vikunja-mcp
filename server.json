{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.joyjit/vikunja-mcp",
  "description": "Maintained fork of the Vikunja MCP server (Vikunja 2.3-ready fixes)",
  "status": "active",
  "repository": {
    "url": "https://github.com/joyjit/vikunja-mcp",
    "source": "github"
  },
  "version": "0.2.7",
  "packages": [
    {
      "registry_type": "npm",
      "registry_base_url": "https://registry.npmjs.org",
      "identifier": "@joyjit/vikunja-mcp",
      "version": "0.2.7",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "description": "Vikunja API base URL (include /api/v1)",
          "is_required": true,
          "format": "string",
          "is_secret": false,
          "name": "VIKUNJA_URL"
        },
        {
          "description": "Vikunja API token (tk_\u2026) or JWT",
          "is_required": true,
          "format": "string",
          "is_secret": true,
          "name": "VIKUNJA_API_TOKEN"
        }
      ]
    }
  ]
}
